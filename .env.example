# ============================================================
# UPI Wallet Backend — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ============================================================

# ── Database ─────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=upi_wallet
DB_USER=root
DB_PASS=

# ── BharatPe API ─────────────────────────────────────────────
# Bearer token from your BharatPe merchant dashboard
BHARATPE_TOKEN=

# Full BharatPe transaction API endpoint URL (include merchant_id in URL if needed)
BHARATPE_API_URL=

# Set to "true" to bypass the real API during local development
BHARATPE_TEST_MODE=false

# ── Limits ───────────────────────────────────────────────────
# Maximum wallet top-up per user per day (in INR)
DAILY_LIMIT_INR=5000

# ── Alerts ───────────────────────────────────────────────────
# Email to notify when BharatPe API fails repeatedly
ADMIN_ALERT_EMAIL=

# ── Admin Panel ───────────────────────────────────────────────
# Admin username
ADMIN_USER=admin

# bcrypt hash of the admin password — generate with:
#   php -r "echo password_hash('your_password', PASSWORD_BCRYPT) . PHP_EOL;"
ADMIN_PASS=
